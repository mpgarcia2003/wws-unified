# ==================================
# Shopify Storefront API
# ==================================
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=worldwideshades.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your_storefront_api_token

# ==================================
# Supabase (shade builder data)
# ==================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ==================================
# Admin Dashboard
# ==================================
ADMIN_PASSWORD=your_admin_password

# ==================================
# Google Gemini (AI features in builder)
# ==================================
GEMINI_API_KEY=your_gemini_api_key

# ==================================
# EmailJS (consultation requests)
# ==================================
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key

# ==================================
# Analytics
# ==================================
NEXT_PUBLIC_GTM_ID=GTM-5THC3H88
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-1RHH50R34P

# ==================================
# Cloudinary (product images)
# ==================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
